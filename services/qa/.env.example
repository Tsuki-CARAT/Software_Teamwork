# AI Gateway chat completion endpoint used by the QA agent and connection tests.
AI_GATEWAY_URL=http://localhost:8086/internal/v1/chat/completions
AI_GATEWAY_TOKEN=
AI_GATEWAY_TOKEN_HEADER=X-Service-Token
MODEL_ID=deepseek-chat
AI_GATEWAY_TIMEOUT=60s

QA_HTTP_ADDR=:8084
QA_DATABASE_URL=postgres://qa_app:qa_app_dev@localhost:5433/qa_system?sslmode=disable
QA_MAX_REQUEST_BYTES=1048576
QA_SHUTDOWN_TIMEOUT=10s
INTERNAL_SERVICE_TOKEN=replace-with-a-long-random-service-token
QA_CONFIG_ENCRYPTION_KEY=replace-with-64-hex-characters

# Auth bootstrap values used by docker-compose.yml.
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=replace-with-at-least-10-characters

AGENT_SYSTEM_PROMPT=You are a helpful QA agent. Use available tools when needed and do not invent sources.
AGENT_MAX_ITERATIONS=8
AGENT_MAX_TOKENS=4096
MCP_TOOL_TIMEOUT=30s
MCP_MAX_RESULT_BYTES=50000

# Built-in Function Calling tools are always available inside AGENT_WORKDIR:
# read_file, write_file, edit_file. The bash tool is opt-in.
AGENT_WORKDIR=.
AGENT_MAX_FILE_BYTES=1048576
AGENT_ENABLE_COMMAND_TOOL=false
AGENT_COMMAND_TIMEOUT=120s

# MCP is optional because built-in tools do not require a server.
MCP_TRANSPORT=disabled

# P0 MCP alternative: launch a local server over stdin/stdout.
# MCP_TRANSPORT=stdio
# MCP_SERVER_COMMAND=python
# MCP_SERVER_ARGS_JSON=["path/to/server.py"]

# P1 alternative: connect to a remote Streamable HTTP MCP server.
# MCP_TRANSPORT=streamable_http
# MCP_SERVER_URL=http://localhost:8090/mcp
# MCP_SERVER_TOKEN=
# MCP_SERVER_TOKEN_HEADER=Authorization
# Internal Knowledge Service base URL used by retrieval test runs.
KNOWLEDGE_SERVICE_URL=http://knowledge:8083
